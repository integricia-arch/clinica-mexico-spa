VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Cloudflare Turnstile site key (publica, no es secreta). Opcional: si se
# omite, el login por correo/contrasena funciona sin captcha (graceful
# degrade). El secret key correspondiente se configura en el dashboard de
# Supabase (Authentication > Settings > Bot and Abuse Protection), NUNCA aqui.
VITE_TURNSTILE_SITE_KEY="your-turnstile-site-key"
