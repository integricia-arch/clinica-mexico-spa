{
  "name": "dedup: mismo update_id dos veces → se procesa solo una vez",
  "steps": [
    {
      "send": { "text": "hola", "update_id": 424242 },
      "expect": [{ "pattern": "¿En qué te puedo ayudar", "min": 1, "max": 1 }]
    },
    {
      "send": { "text": "hola", "update_id": 424242 },
      "expect": [{ "pattern": "¿En qué te puedo ayudar", "min": 0, "max": 0 }]
    }
  ]
}
